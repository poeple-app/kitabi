# Kitabi — environment configuration template
# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env` with real values — `.gitignore` excludes it.

# ─── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ALLOWED_TG_USER_IDS=                  # comma-separated Telegram user IDs
WEBHOOK_SECRET=                        # python -c "import secrets; print(secrets.token_hex(32))"

# ─── Gemini ───────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Google Cloud (hosting + DB persistence) ──────────────────
GCP_PROJECT_ID=
GCS_BUCKET_NAME=
CLOUD_RUN_REGION=europe-west1
BOT_BASE_URL=                          # filled in after first Cloud Run deploy

# ─── Application ──────────────────────────────────────────────
ENVIRONMENT=development                # development | production
LOG_LEVEL=INFO

# ─── Notion sync (OPTIONAL — leave blank to disable) ──────────
# NOTION_TOKEN=
# NOTION_DB_KITAP=
# NOTION_DB_OKUMA=
# NOTION_DB_NOT=
